<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="favicon.png">
  <title>{{ .Title }} - Melonlorrd's Blog</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Iosevka+Charon+Mono:wght@400;700;800&display=swap" rel="stylesheet">

  <style>
    :root {
      --max-width: 680px;
      --font-mono: 'Iosevka Charon Mono', ui-monospace, SFMono-Regular, monospace;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --space-1: #030509; --space-2: #060a14; --space-3: #0a1120;
        --space-4: #0f182d; --space-5: #152240;
        --fg: #d0d8e6; --fg-muted: #8496b0;
        --link: #6fe7d2; --star: #fce883;

        --win-bg: #060a14; --win-border: #fce883;
        --titlebar-bg: #fce883; --titlebar-fg: #060a14;

        --heading: #fce883;
        --tui-select: #fce883; --tui-select-fg: #060a14;

        --code-bg: transparent; --code-border: #8496b0;
        --inline-bg: #152240; --inline-fg: #6fe7d2;
      }
    }

    @media (prefers-color-scheme: light) {
      :root {
        --space-1: #f8fafc; --space-2: #f0f4f8; --space-3: #e2e8f0;
        --space-4: #cbd5e1; --space-5: #b2c0d0;

        --fg: #1e293b; --fg-muted: #64748b;
        --link: #0ea5e9; --star: #ffffff;

        --win-bg: #ffffff; --win-border: #0f172a;
        --titlebar-bg: #0f172a; --titlebar-fg: #ffffff;

        --heading: #0f172a;
        --tui-select: #0f172a; --tui-select-fg: #ffffff;

        --code-bg: transparent; --code-border: #94a3b8;
        --inline-bg: #f1f5f9; --inline-fg: #0ea5e9;
      }
    }

    * { box-sizing: border-box; }

    body {
      margin: 0; background-color: var(--space-5);
      background-image: linear-gradient(to bottom,
        var(--space-1) 0%,   var(--space-1) 20vh,
        var(--space-2) 20vh, var(--space-2) 40vh,
        var(--space-3) 40vh, var(--space-3) 60vh,
        var(--space-4) 60vh, var(--space-4) 80vh,
        var(--space-5) 80vh, var(--space-5) 100vh
      );
      background-attachment: fixed; color: var(--fg);
      font-family: var(--font-mono);
      font-size: 16px;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased; padding: 3rem 1rem;
    }

    body::before, body::after {
      content: ""; position: fixed; inset: 0;
      z-index: -2; pointer-events: none; background-attachment: fixed;
    }
    body::before {
      background-image:
        radial-gradient(1.5px 1.5px at 40px 60px, var(--star) 100%, transparent),
        radial-gradient(1px 1px at 200px 40px, var(--star) 100%, transparent);
      background-size: 200px 200px, 150px 150px;
      animation: twinkle 4s ease-in-out infinite alternate;
    }
    body::after {
      background-image:
        radial-gradient(2px 2px at 150px 120px, var(--star) 100%, transparent),
        radial-gradient(1.5px 1.5px at 80px 220px, var(--star) 100%, transparent);
      background-size: 300px 300px, 250px 250px;
      animation: twinkle 3s ease-in-out infinite alternate-reverse;
    }
    @keyframes twinkle { 0% { opacity: 0.2; } 100% { opacity: 1; } }

    .screensaver {
      position: fixed; inset: 0; z-index: -1;
      pointer-events: none; overflow: hidden;
      opacity: 0; visibility: hidden;
      transition: opacity 1.5s ease-in-out, visibility 1.5s ease-in-out;
    }

    #win-min:checked ~ .screensaver { opacity: 1; visibility: visible; }

    #win-min:checked ~ .screensaver .sat-1,
    #win-min:checked ~ .screensaver .sat-2 {
      animation-play-state: running;
    }

    .css-sat-body {
      position: absolute;
      width: 16px; height: 16px;
      background: var(--fg);
      border-radius: 2px;
      box-shadow: 0 0 10px rgba(0,0,0,0.5);
    }

    .css-sat-body::before, .css-sat-body::after {
      content: ""; position: absolute;
      top: 3px; width: 35px; height: 10px;
      background: var(--link);
      border: 1px solid var(--space-4);
      opacity: 0.9;
    }
    .css-sat-body::before { right: 100%; margin-right: 4px; }
    .css-sat-body::after { left: 100%; margin-left: 4px; }

    .css-sat-antenna {
      position: absolute; bottom: 100%; left: 7px;
      width: 2px; height: 12px; background: var(--fg-muted);
    }
    .css-sat-antenna::after {
      content: ""; position: absolute; top: -4px; left: -3px;
      width: 8px; height: 3px; background: var(--heading);
      border-radius: 50%;
    }

    .sat-1 { animation: orbit-1 35s linear infinite paused; }
    .sat-2 { animation: orbit-2 50s linear infinite paused; opacity: 0.6; }

    @keyframes orbit-1 {
      0% { transform: translate(-30vw, 85vh) rotate(20deg); }
      100% { transform: translate(120vw, 15vh) rotate(50deg); }
    }
    @keyframes orbit-2 {
      0% { transform: translate(120vw, 35vh) rotate(-15deg) scale(0.6); }
      100% { transform: translate(-30vw, 75vh) rotate(-45deg) scale(0.6); }
    }

    @media (max-width: 600px) { .screensaver { display: none; } }

    .os-window {
      max-width: var(--max-width);
      margin: 0 auto; background-color: var(--win-bg);
      border: 2px solid var(--win-border);
      border-radius: 8px; overflow: hidden;
      transition: max-width 0.3s ease;
      position: relative; z-index: 10;
    }

    .os-titlebar {
      background-color: var(--titlebar-bg); color: var(--titlebar-fg);
      padding: 0.6rem 1rem; border-bottom: 2px solid var(--win-border);
      display: grid; grid-template-columns: 60px 1fr 60px;
      align-items: center; user-select: none;
    }

    .os-controls { display: flex; gap: 8px; align-items: center; }

    .ctrl-btn {
      width: 12px; height: 12px; border-radius: 50%;
      cursor: pointer; position: relative;
      box-shadow: inset 0 0 0 1px rgba(0,0,0,0.15); transition: opacity 0.1s;
    }
    .btn-close { background-color: var(--fg-muted); cursor: not-allowed; opacity: 0.5; }
    .btn-min   { background-color: #ffbd2e; }
    .btn-max   { background-color: #27c93f; }
    .ctrl-btn:active:not(.btn-close) { opacity: 0.6; }

    .os-title {
      font-weight: 800; font-size: 0.85rem; letter-spacing: -0.5px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
      text-align: center;
    }

    .os-content { padding: 2rem; }

    #win-max:checked ~ .os-window { max-width: 95vw; }
    #win-min:checked ~ .os-window .os-content { display: none; }

    main { margin: 0; padding: 0; }

    a {
      color: var(--link); text-decoration: underline; text-decoration-thickness: 1px;
      text-underline-offset: 3px; font-weight: 700; cursor: pointer;
    }
    @media (hover: hover) {
      a:hover { background-color: var(--tui-select); color: var(--tui-select-fg); text-decoration: none; }
    }

    .back {
      display: inline-block; margin-bottom: 2rem; font-size: 0.85rem;
      border: 1px solid var(--win-border); color: var(--fg);
      padding: 0.3rem 0.6rem; text-decoration: none;
    }
    .back::before { content: "$ "; font-weight: bold; color: var(--heading); }

    header { margin-bottom: 2.5rem; border-bottom: 1px solid var(--win-border); padding-bottom: 1rem; }
    header h1 {
      color: var(--heading); font-size: clamp(1.4rem, 4vw, 1.8rem); line-height: 1.2;
      margin: 0 0 0.5rem 0; font-weight: 800; text-transform: uppercase;
      letter-spacing: -0.5px;
    }
    header time {
      display: inline-block; color: var(--fg-muted); font-size: 0.8rem;
    }
    header time::before { content: "DATE: "; font-weight: bold; }

    article p { margin: 0 0 1.25rem; }

    article h2, article h3, article h4 {
      color: var(--heading); margin: 2rem 0 1rem 0; font-size: 1.15rem;
      font-weight: 800; display: inline-block;
    }

    article img {
      max-width: 100%; height: auto; display: block; margin: 1.5rem 0;
      border: 1px solid var(--code-border);
    }

    article ul, article ol { padding-left: 1.25rem; margin: 0 0 1.25rem 0; }
    article li { margin: 0.4rem 0; }
    article li::marker { color: var(--heading); font-weight: bold; }

    article blockquote {
      margin: 1.5rem 0; padding: 1rem;
      border-left: 4px solid var(--heading);
      background-color: var(--inline-bg);
      color: var(--fg); font-style: italic;
    }

    pre, code {
      font-family: var(--font-mono);
    }

    pre {
      background-color: var(--code-bg); color: var(--fg);
      border: 1px solid var(--code-border); padding: 1rem;
      overflow-x: auto; margin: 1.5rem 0; font-size: 0.85rem;
    }

    p code, li code {
      background-color: var(--inline-bg); color: var(--inline-fg);
      padding: 0.15rem 0.35rem; font-size: 0.85em; font-weight: 700;
    }

    @media (max-width: 600px) {
      body { padding: 0; }
      .os-window {
        max-width: 100vw;
        min-height: 100vh;
        border-radius: 0;
        border: none;
      }
      .os-titlebar { display: none; }
      .os-content { padding: 1.5rem 1rem; }
      pre { font-size: 0.85rem; padding: 0.85rem; }
    }
  </style>
</head>

<body>
  <input type="checkbox" id="win-min" hidden>
  <input type="checkbox" id="win-max" hidden>

  <div class="screensaver">
    <div class="css-sat-body sat-1">
      <div class="css-sat-antenna"></div>
    </div>

    <div class="css-sat-body sat-2">
      <div class="css-sat-antenna"></div>
    </div>
  </div>

  <div class="os-window">
    <div class="os-titlebar">
      <div class="os-controls">
        <span class="ctrl-btn btn-close" title="Close (Disabled)"></span>
        <label for="win-min" class="ctrl-btn btn-min" title="Minimize / Shade"></label>
        <label for="win-max" class="ctrl-btn btn-max" title="Maximize"></label>
      </div>
      <div class="os-title">~/reader.sh</div>
      <div></div>
    </div>

    <div class="os-content">
      <main>
        <a class="back" href="index.html">cd ..</a>

        <header>
          <h1>{{ .Title }}</h1>
          <time>{{ .Date.Format "2006.01.02" }}</time>
        </header>

        <article>
          {{ .HTML }}
        </article>
      </main>
    </div>
  </div>

  <script>
    (function() {
      const minBtn = document.getElementById('win-min');
      const maxBtn = document.getElementById('win-max');
      const savedState = localStorage.getItem('melonlorrd_os_state');

      if (savedState === 'min') minBtn.checked = true;
      if (savedState === 'max') maxBtn.checked = true;

      minBtn.addEventListener('change', () => {
        if (minBtn.checked) {
          maxBtn.checked = false;
          localStorage.setItem('melonlorrd_os_state', 'min');
        } else {
          localStorage.setItem('melonlorrd_os_state', 'normal');
        }
      });

      maxBtn.addEventListener('change', () => {
        if (maxBtn.checked) {
          minBtn.checked = false;
          localStorage.setItem('melonlorrd_os_state', 'max');
        } else {
          localStorage.setItem('melonlorrd_os_state', 'normal');
        }
      });
    })();

    // Lightweight script to keep the TUI button-press feel on click
    document.addEventListener('click', function(e) {
      let link = e.target.closest('a');
      if (link) {
        e.preventDefault();

        if (link.dataset.loading === "true") return;
        link.dataset.loading = "true";

        const isExternal = link.getAttribute('target') === '_blank';

        // Apply selected TUI colors
        link.style.backgroundColor = "var(--tui-select)";
        link.style.color = "var(--tui-select-fg)";
        link.style.textDecoration = "none";

        // Short delay to register the visual click, then navigate
        setTimeout(() => {
          if (isExternal) {
            window.open(link.href, '_blank');
            // Reset styles for external links so page acts normal upon return
            setTimeout(() => {
              link.dataset.loading = "false";
              link.style.backgroundColor = "";
              link.style.color = "";
              link.style.textDecoration = "";
            }, 100);
          } else {
            window.location.href = link.href;
          }
        }, 150);
      }
    });
  </script>
</body>
</html>
