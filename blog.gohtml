<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="favicon.png">
  <title>{{ .Title }} - Melonlorrd's Blog</title>

  <style>
    :root {
      --bg: #ffffff;
      --text: #1a1a1a;
      --text-muted: #666666;
      --link: #0055cc;
      --link-hover: #003399;
      --border: #eaeaea;
      --code-bg: #f5f5f5;
      --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --font-mono: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #121212;
        --text: #e0e0e0;
        --text-muted: #a0a0a0;
        --link: #66b3ff;
        --link-hover: #99ccff;
        --border: #333333;
        --code-bg: #1e1e1e;
      }
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 2rem 1rem;
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    main {
      max-width: 42rem;
      margin: 0 auto;
    }

    nav {
      margin-bottom: 2.5rem;
      font-size: 0.9375rem;
    }

    a {
      color: var(--link);
      text-decoration: none;
    }

    a:hover {
      color: var(--link-hover);
      text-decoration: underline;
    }

    header {
      margin-bottom: 2rem;
    }

    h1 {
      font-size: 1.5rem;
      margin: 0 0 0.25rem 0;
      line-height: 1.2;
      font-weight: 600;
    }

    header time {
      font-family: var(--font-mono);
      color: var(--text-muted);
      font-size: 0.875rem;
    }

    article {
      font-size: 0.9375rem; /* Slight step down for easier reading lengths */
    }

    article h2 {
      font-size: 1.25rem;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
    }

    article h3 {
      font-size: 1.125rem;
      margin-top: 1.5rem;
      margin-bottom: 0.75rem;
      font-weight: 600;
    }

    article p {
      margin-bottom: 1.25rem;
    }

    article img {
      max-width: 100%;
      height: auto;
      border-radius: 0.25rem;
      margin: 1.5rem 0;
    }

    article blockquote {
      margin: 1.5rem 0;
      padding: 0.5rem 1rem;
      border-left: 0.25rem solid var(--border);
      color: var(--text-muted);
      font-style: italic;
    }

    pre, code {
      font-family: var(--font-mono);
      font-size: 0.875rem;
    }

    code {
      background-color: var(--code-bg);
      padding: 0.125rem 0.25rem;
      border-radius: 0.1875rem;
    }

    pre {
      background-color: var(--code-bg);
      padding: 1rem;
      border-radius: 0.375rem;
      overflow-x: auto;
      margin: 1.5rem 0;
    }

    pre code {
      background-color: transparent;
      padding: 0;
      border-radius: 0;
    }

    article ul, article ol {
      padding-left: 1.5rem;
      margin-bottom: 1.25rem;
    }

    article li {
      margin-bottom: 0.5rem;
    }
  </style>
</head>

<body>
  <main>
    <nav>
      <a href="index.html">← Back to home</a>
    </nav>

    <article>
      <header>
        <h1>{{ .Title }}</h1>
        <time>{{ .Date.Format "2006.01.02" }}</time>
      </header>

      <div class="content">
        {{ .HTML }}
      </div>
    </article>
  </main>
</body>
</html>
