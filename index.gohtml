<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="icon" type="image/png" href="favicon.png">
  <link rel="alternate" type="application/rss+xml" title="Melonlorrd's Blog" href="rss.xml">
  <title>Melonlorrd's Blog</title>

  <style>
    :root {
      --bg: #ffffff;
      --text: #1a1a1a;
      --text-muted: #666666;
      --link: #0055cc;
      --link-hover: #003399;
      --border: #eaeaea;
      --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      --font-mono: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #121212;
        --text: #e0e0e0;
        --text-muted: #a0a0a0;
        --link: #66b3ff;
        --link-hover: #99ccff;
        --border: #333333;
      }
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      padding: 2rem 1rem;
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-sans);
      font-size: 1rem;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    main {
      max-width: 42rem;
      margin: 0 auto;
    }

    h1, h2, h3 {
      color: var(--text);
      margin-top: 2rem;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    p { margin: 0 0 1rem; }

    a {
      color: var(--link);
      text-decoration: none;
    }

    a:hover {
      color: var(--link-hover);
      text-decoration: underline;
    }

    header {
      margin-bottom: 2.5rem;
    }

    header h1 {
      margin: 0;
      font-size: 1.25rem;
    }

    .bio {
      margin-bottom: 3rem;
      font-size: 0.9375rem;
    }

    .social-links {
      display: flex;
      gap: 1rem;
      margin-top: 1rem;
    }

    .posts h2 {
      font-size: 1.125rem;
    }

    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .post-list li {
      display: flex;
      flex-direction: column;
      margin-bottom: 1.25rem;
    }

    @media (min-width: 32rem) {
      .post-list li {
        flex-direction: row;
        align-items: baseline;
        gap: 1.5rem;
      }
    }

    .post-list time {
      font-family: var(--font-mono);
      font-size: 0.875rem;
      color: var(--text-muted);
      min-width: 6.5rem;
    }

    .post-list a {
      font-size: 1rem;
    }

    footer {
      max-width: 42rem;
      margin: 4rem auto 0;
      font-size: 0.9375rem;
    }

    footer p {
      color: var(--text-muted);
      margin: 0.5rem 0 0;
    }
  </style>
</head>

<body>
  <main>
    <header>
      <h1>Melonlorrd's Blog</h1>
    </header>

    <section class="bio">
      <p>Hello. I'm Mahaprasad, passionate about Infrastructure and Systems Engineering. Currently exploring the cloud at AceCloud as a DevOps Engineer. In the quiet hours, I enjoy Music and Sketching.</p>
      <div class="social-links">
        <a href="https://www.linkedin.com/in/mprasadme" target="_blank">LinkedIn</a>
        <a href="https://github.com/melonlorrd" target="_blank">GitHub</a>
        <a href="rss.xml" target="_blank">RSS</a>
      </div>
    </section>

    <section class="posts">
      <h2>Writing</h2>
      <ul class="post-list">
        {{ range .Blogs }}
        <li>
          <time>{{ .Date.Format "2006.01.02" }}</time>
          <a href="{{ .Slug }}.html">{{ .Title }}</a>
        </li>
        {{ end }}
      </ul>
    </section>
  </main>

  <footer>
    <p>Last updated from {{ .BuildTime }}</p>
  </footer>
</body>
</html>
